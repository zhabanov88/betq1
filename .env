# ═══════════════════════════════════════════════
#  BetQuant Pro — Environment Configuration
#  Скопируй: cp .env.example .env
#  Затем заполни нужные значения
# ═══════════════════════════════════════════════

# ── Сервер ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# Секрет для сессий (смени в production!)
SESSION_SECRET=change-me-to-random-string-in-production

# ── PostgreSQL (users, strategies, journal) ─────
# Оставь пустым для работы без БД (demo mode)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=betquant
PG_USER=betquant
PG_PASSWORD=betquant123

# ── ClickHouse (match data, odds, backtests) ────
# Оставь пустым для работы без БД (demo mode)
CH_HOST=http://localhost:8123
CH_USER=default
CH_PASSWORD=
CH_DATABASE=betquant

# ── AI Strategy Generator ───────────────────────
# Получи ключ на: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Уведомления (опционально) ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Внешние API (опционально) ───────────────────
BETFAIR_APP_KEY=
PINNACLE_API_KEY=

ODDS_API_KEY=78bf5b1c5f18f7153782b6ba7e5156ce